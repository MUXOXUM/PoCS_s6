ort user_notice_2\n\n# generated\n# Опишите эту функцию…\ndef check_user_data(form_result):\n    log_process(window_log=True,block_text='Присвоить значение переменной')\n    #IA@z|~sLL)At//{C+BM*\n    email = form_result['contest_email']\n\n    log_process(block_text='Присвоить значение переменной')\n\n    log_process(window_log=True,block_text='Присвоить значение переменной')\n    #$m/v=1Z^N;HrIA~Rbb{7\n    age = form_result['contestant_age']\n\n    log_process(block_text='Присвоить значение переменной')\n\n    log_process(window_log=True,block_text='Присвоить значение переменной')\n    #f9b`HZ*vwdr~B2z8}Uy@\n    check_box = form_result['has_portfolio']\n\n    log_process(block_text='Присвоить значение переменной')\n\n    log_process(window_log=True,block_text='Если – выполнить')\n    #MqR{ua7IH/V@BGM$w+^p\n    if (age >= 16 or check_box == True) and (sootv_str.sootv_str(email,'@',block_text=\"Содержит ли строка подстроку\",window_log=True, current_language=\"ru\")) and email[int(len(email) - 4) : int(len(email) + 1)] != 'test':\n        #oHCQ+1Y;Gsiu1xZ-G:.Z\n        user_notice_2.user_notice('Заявка соответствует требованиям конкурса',None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n    else:\n        #DT8rc}H|gAt.Cq-W?O5P\n        user_notice_2.user_notice('Ошибка: неверный email или возраст без портфолио',None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n\n    log_process(block_text='Если – выполнить')\n\n\n\nlogger = configure_logger()\npuzzle_logger_path = Path(__file__).absolute()\nlogger.info(f'Старт робота: {puzzle_logger_path}')\n\nif __name__ == \"__main__\":\n    def main_spark_669_proc():\n        try:\n            log_process(window_log=True,block_text='Присвоить значение переменной')\n            #Cx^N]1K?51NVY}kVFxu8\n            application_count = 0\n\n            log_process(block_text='Присвоить значение переменной')\n\n            log_process(window_log=True,block_text='Цикл повторить n-раз')\n            #y6SCH3-(j7YWQBlSU|M5\n            for count in range(10):\n                # Присваивает переменной значение вставки\n                log_process(window_log=True,block_text='Присвоить значение переменной')\n                #E^[(=2L5s@0YdNHtkN{9\n                form_result = dynamic_form.show_form((files_and_folders.get_executable_path('forms/form_4.2.json',binary_path='TRUE',block_text=\"Относительный путь\",window_log=True, current_language=\"ru\")),fields_defaults=None,callback_context=None,block_text=\"undefined\",window_log=True, current_language=\"ru\")\n\n                log_process(block_text='Присвоить значение переменной')\n\n                log_process(window_log=True,block_text='Если – выполнить')\n                #OXDZkkNVwYBM_Z5(k=_t\n                if not len(form_result):\n                    log_process(window_log=True,block_text='Выйти из цикла')\n                    #_4|vqU(HnG!#_.k}xra@\n                    break\n\n                    log_process(block_text='Выйти из цикла')\n\n\n                log_process(block_text='Если – выполнить')\n\n                log_process(window_log=True,block_text='Присвоить значение переменной')\n                #E7+(#~*GkV*BD_ze(a5!\n                line = ''.join([str(x) for x in [form_result['contestant_name'], ';', form_result['contest_email'], ';', form_result['contestant_age'], ';', form_result['has_portfolio'], ';']])\n\n                log_process(block_text='Присвоить значение переменной')\n\n                log_process(window_log=True,block_text='Если – выполнить')\n                #riV[O=l7@gpFQ$_-Wt*}\n                if (form_result['has_portfolio']) == True:\n                    log_process(window_log=True,block_text='Присвоить значение переменной')\n                    #iv_3K071p%f+tbPSQ#xF\n                    line = ''.join([str(x2) for x2 in [line, form_result['portfolio_link'], ';', form_result['contest_nomination'], ('' + '\\n' +\n                    '')]])\n\n                    log_process(block_text='Присвоить значение переменной')\n\n                else:\n                    log_process(window_log=True,block_text='Присвоить значение переменной')\n                    #0604HWKY-0k8[jELoiOx\n                    line = ''.join([str(x3) for x3 in [line, ';', form_result['contest_nomination'], ('' + '\\n' +\n                    '')]])\n\n                    log_process(block_text='Присвоить значение переменной')\n\n\n                log_process(block_text='Если – выполнить')\n\n                #acZ3qVt/8qr7jNEbB-v~\n                files_and_folders.append_txt_file(file_path=(files_and_folders.get_executable_path('contest_application_extended.csv',binary_path='TRUE',block_text=\"Относительный путь\",window_log=True, current_language=\"ru\")), data=line, encoding='utf-8',block_text=\"Дописать в файл\",window_log=True, current_language=\"ru\")\n\n                log_process(window_log=True,block_text='Увеличить значение переменной')\n                #Jv).}m[]2V!X8wH|BMn*\n                application_count = (application_count if isinstance(application_count, Number) else 0) + 1\n\n                log_process(block_text='Увеличить значение переменной')\n\n\n            log_process(block_text='Цикл повторить n-раз')\n\n            #3,%!T#l@K4w?pAt`U}Rn\n            user_notice_2.user_notice((f\"Принято заявок на конкурс: {application_count}\"),None,block_text=\"Уведомление пользователя\",window_log=True, current_language=\"ru\")\n\n\n            logger.info(f'Завершение работы робота: {puzzle_logger_path}')\n            send_message_websocket(message_type=\"python_end\")\n        except Exception as error_puzzle:\n            logger.error(f'{puzzle_logger_path} ' + f'Ошибка: {error_puzzle}')\n            error_puzzle_format=format_traceback(error_puzzle)\n            send_message_websocket(message_type=\"python_error\", message=error_puzzle_format)\n            raise Exception(error_puzzle)\n    main_spark_669_proc()